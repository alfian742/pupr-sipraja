APP_NAME="SI PRAJA"
APP_SUBNAME="DPUPR Kabupaten Lombok Tengah"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Makassar
APP_URL=https://sipraja.lomboktengahkab.go.id

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=sipraja
DB_USERNAME=sipraja
DB_PASSWORD=ganti_password_database_yang_kuat
MYSQL_ROOT_PASSWORD=ganti_password_root_mysql_yang_kuat

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
DB_QUEUE_RETRY_AFTER=1500

CACHE_STORE=database
CACHE_PREFIX=sipraja

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_ENCRYPTION=tls
MAIL_HOST=smtpauth.mail.go.id
MAIL_PORT=587
MAIL_USERNAME=noreply.sipraja@lomboktengahkab.go.id
MAIL_PASSWORD=ganti_password_email_asli
MAIL_FROM_ADDRESS="noreply.sipraja@lomboktengahkab.go.id"
MAIL_FROM_NAME="${APP_SUBNAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

VITE_APP_NAME="${APP_NAME}"
